# --- Disallow crawling of private or functional paths ---
# These pages are user-specific, contain no valuable SEO content,
# or are part of the application's functional flow.

# User account and authentication pages
Disallow: /account
Disallow: /login
Disallow: /logout
Disallow: /auth/
Disallow: /delete_account

# Quiz and assessment process pages
Disallow: /quiz/
Disallow: /assessment/
