# Quiz generator pages (the results in the bank are more valuable to index)
Disallow: /autoquiz
Disallow: /guidedquiz

# Error pages
Disallow: /error/


# --- Explicitly allow crawling of public content ---
# While this is the default behavior if not disallowed, being explicit can be helpful.
# These pages contain the public-facing content you want indexed by search engines.

Allow: /
Allow: /bank/
Allow: /about
Allow: /contact
Allow: /feedback
Allow: /tnc
Allow: /privacy-policy
